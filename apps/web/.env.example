# Frontend env vars (Vite reads these at build time).
# Copy this file to `.env.local` for local dev, or set the same key in
# Cloudflare Pages → Settings → Environment Variables for production.

# Full origin of the PocketBase backend (no trailing slash).
# Production example: VITE_PB_URL=https://checksquare-pb.fly.dev
# Local example:      VITE_PB_URL=http://127.0.0.1:8090
# Leave blank to fall back to the Hostinger-style '/hcgi/platform' proxy.
VITE_PB_URL=


# ── Supabase side-car (Phase 1: Storage + Auth) ─────────────────────
# Both keys come from Supabase Dashboard → Project Settings → API.
# Leave BOTH empty to disable Supabase — the app falls back to
# PocketBase-only behaviour automatically (see lib/supabaseClient.js).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Phase 3 cutover toggle ──────────────────────────────────────────
# Set to `true` AFTER you have run supabase/migrations/* and
# scripts/migrate-pb-to-supabase.mjs.  When true, every CRUD call in
# apps/web/src/services/dataService.js routes to Supabase Postgres
# instead of PocketBase.  Leave blank or `false` during Phase 1/2.
VITE_USE_SUPABASE_DB=
