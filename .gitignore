# ─── Node ────────────────────────────────────────────────────────────────────
node_modules/
.npm/
.pnpm-store/
.yarn/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Build output ────────────────────────────────────────────────────────────
dist/
build/
.vite/
.cache/
*.tsbuildinfo

# ─── PocketBase (DB + uploads + binary) ──────────────────────────────────────
# pb_data contains the entire SQLite DB and every uploaded file (avatars,
# room photos, etc.). Keep it OUT of git — it's huge and per-environment.
apps/pocketbase/pb_data/
apps/pocketbase/pocketbase
apps/pocketbase/pocketbase.exe
apps/pocketbase/pb_snapshots/

# ─── Local backup zips (created by backup-pb.ps1) ────────────────────────────
# These contain hashed passwords + all uploaded files. NEVER commit them.
backups/
*.bak.zip
pb_backup_*.zip

# ─── Environment / secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Editor / OS ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Test / coverage ─────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Memory / agent scratch ──────────────────────────────────────────────────
/memories/session/

# ─── Capacitor / Android (native shell, regenerated by `npx cap add`) ────────
# Don't commit the android/ folder — it's huge, contains generated gradle
# wrappers, and is rebuilt fresh from capacitor.config.json + dist/ each time.
apps/web/android/
apps/web/ios/
apps/web/.capacitor/
*.apk
*.aab
*.keystore
*.jks
